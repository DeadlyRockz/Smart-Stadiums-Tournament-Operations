# Gemini API key from Google AI Studio (free tier works).
# GOOGLE_API_KEY is also accepted by the SDK and wins if both are set.
GEMINI_API_KEY=

# Optional: distributed rate limiting across replicas behind a load balancer.
# Leave unset to use the in-memory limiter (fine for a single process). If set
# but unreachable, the app logs a warning and falls back to in-memory.
# REDIS_URL=redis://localhost:6379/0
